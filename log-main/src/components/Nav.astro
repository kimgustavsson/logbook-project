---
// Top navigation. No logo. On desktop the links sit inline in the bar;
// on mobile they collapse behind a hamburger toggle that opens a
// full-screen overlay menu. Links are passed in so the same bar works on
// any page.
const links = [
  { label: 'Dev Log', href: '/devlog' },
  { label: 'Writing', href: '/writing' },
  { label: 'About', href: '/about' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/', external: true },
];
---

<nav id="nav">
  <div class="nav-inner">
    <button class="menu-toggle" id="mtoggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
    <div class="nav-links" id="navlinks">
      <a href="/" class="home-link">Home</a>
      {links.map((l) =>
        l.external ? (
          <a class="ext" href={l.href} target="_blank" rel="noopener">{l.label}</a>
        ) : (
          <a href={l.href}>{l.label}</a>
        )
      )}
    </div>
  </div>
</nav>

<style>
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 28px clamp(20px, 5vw, 56px); transition: background .4s ease, border-color .4s ease, padding .4s ease; border-bottom: 1px solid transparent; transform: translateZ(0); will-change: background-color; }
  nav.scrolled { background: rgba(242, 240, 234, .92); backdrop-filter: blur(14px); border-bottom: 1px solid var(--line); }
  .nav-inner { max-width: var(--maxw-content); margin: 0 auto; display: flex; align-items: center; justify-content: flex-end; }

  /* hamburger: three plain bars, no circle/border. A whole-pixel height
     (not 1.5px) keeps all three rendering at the same weight — a
     sub-pixel height anti-aliases inconsistently depending on where it
     lands on the pixel grid, making bars look unevenly thick. */
  .menu-toggle { display: flex; flex-direction: column; justify-content: center; gap: 5px; width: 26px; height: 20px; background: none; border: none; padding: 0; cursor: pointer; z-index: 60; }
  .menu-toggle .bar { display: block; width: 100%; height: 2px; background: var(--luxe); transition: transform .3s ease, opacity .3s ease; }
  .menu-toggle[aria-expanded="true"] .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-toggle[aria-expanded="true"] .bar:nth-child(2) { opacity: 0; }
  .menu-toggle[aria-expanded="true"] .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-links { position: fixed; top: 0; left: 0; right: 0; height: 100vh; background: var(--white); flex-direction: column; justify-content: center; align-items: center; gap: 30px; font-size: 24px; display: flex; transform: translateY(-100%); transition: transform .45s ease; }
  .nav-links.open { transform: translateY(0); }
  .nav-links a { position: relative; padding: 3px 0; color: var(--luxe); opacity: .9; transition: opacity .25s; }
  .nav-links a::after { content: ""; position: absolute; left: 0; bottom: -2px; height: 1px; width: 0; background: currentColor; transition: width .3s ease; }
  .nav-links a:hover { opacity: 1; }
  .nav-links a:hover::after { width: 100%; }
  .home-link { display: block; }

  /* desktop: links sit inline in the bar instead of behind the hamburger,
     which only makes sense as a space-saving move on narrow screens */
  @media (min-width: 761px) {
    .menu-toggle { display: none; }
    .nav-links {
      position: static;
      height: auto;
      transform: none;
      flex-direction: row;
      gap: clamp(18px, 2.4vw, 34px);
      font-size: 14px;
      letter-spacing: .01em;
      background: transparent;
    }
    .home-link { display: none; }
  }
</style>

<script>
  // Toggle the opaque background once the user scrolls past the hero top.
  // Reads scrollY in a rAF tick (not on every raw scroll event) and only
  // touches the DOM when the threshold is actually crossed, so the
  // backdrop-filter blur isn't recomputed on every scroll tick.
  const nav = document.getElementById('nav');
  let isScrolled = false;
  let ticking = false;
  addEventListener(
    'scroll',
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const shouldScroll = scrollY > 40;
        if (shouldScroll !== isScrolled) {
          isScrolled = shouldScroll;
          nav?.classList.toggle('scrolled', isScrolled);
        }
        ticking = false;
      });
    },
    { passive: true }
  );

  // Menu open/close.
  const toggle = document.getElementById('mtoggle');
  const linksEl = document.getElementById('navlinks');
  toggle?.addEventListener('click', () => {
    const open = linksEl?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  linksEl?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      linksEl.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );
</script>
