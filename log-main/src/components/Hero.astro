---
// Hero: full-height intro with a dominant serif headline, a supporting line,
// and a bottom meta bar — name/bio on the left, post-count stats on the right,
// and an "All Articles" CTA. Counts are passed from the page so the numbers
// stay accurate without duplicating the data-fetch logic.
interface Props {
  headline?: string;
  sub?: string;
  name?: string;
  caption?: string;
  devlogCount?: number;
  writingCount?: number;
}
const {
  headline = 'This space is an archive of my experiments and everyday problem-solving.',
  sub = 'It is where I test ideas, hit technical roadblocks, and relentlessly figure out how to make them work.',
  name = 'My name here',
  caption = 'MSc in Artificial Intelligence\nBased in Brisbane, Australia',
  devlogCount = 0,
  writingCount = 0,
} = Astro.props;
---

<header class="hero" id="top">
  <div class="h-spotlight" aria-hidden="true"></div>

  <div class="hero-inner">
    <h1 class="h-head">{headline}</h1>
    <p class="h-sub fade-up" data-delay="200">{sub}</p>
  </div>

  <div class="h-meta fade-up" data-delay="300">
    <div class="blk-name">
      <h4>{name}</h4>
      <div class="v" set:html={caption.replace(/\n/g, '<br>')} />
    </div>
    <div class="blk-right">
      <div class="blk-stats">
        <div class="stat">
          <span class="stat-num">{String(devlogCount).padStart(2, '0')}</span>
          <span class="stat-label">Dev Log</span>
        </div>
        <div class="stat">
          <span class="stat-num">{String(writingCount).padStart(2, '0')}</span>
          <span class="stat-label">Writing</span>
        </div>
      </div>
      <a class="all-articles" href="/devlog">All Articles <span class="arr">→</span></a>
    </div>
  </div>

  <div class="h-scroll" aria-label="Scroll down">
    <svg viewBox="0 0 16 11"><path d="M2 9L8 3l6 6" /></svg>
    <svg viewBox="0 0 16 11"><path d="M2 2l6 6 6-6" /></svg>
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* soft cursor-tracking light */
  .h-spotlight {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity .4s ease;
    background: radial-gradient(
      480px circle at var(--mx, 50%) var(--my, 40%),
      rgba(80, 138, 168, 0.10),
      transparent 70%
    );
  }
  .h-spotlight.active { opacity: 1; }

  /* headline + sub text, centered vertically with nav offset */
  .hero-inner {
    flex: 1;
    width: 100%;
    max-width: var(--maxw-content);
    margin: 0 auto;
    padding: clamp(110px, 19vh, 190px) clamp(24px, 9vw, 140px) clamp(36px, 7vh, 72px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .h-head {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(44px, 6.5vw, 86px);
    line-height: 1.06;
    letter-spacing: -0.022em;
    color: var(--luxe);
    max-width: 20ch;
    margin-bottom: 28px;
  }

  .h-sub {
    font-size: clamp(14px, 1.3vw, 16px);
    line-height: 1.68;
    color: var(--muted);
    max-width: 44ch;
  }

  /* bottom meta bar -------------------------------------------------- */
  .h-meta {
    width: 100%;
    max-width: var(--maxw-content);
    margin: 0 auto clamp(72px, 12vh, 130px);
    padding: 26px clamp(24px, 9vw, 140px) 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    border-top: 1px solid var(--line);
  }

  .blk-name h4 {
    font-size: 14px;
    font-weight: 600;
    color: var(--luxe);
    margin-bottom: 8px;
  }
  .blk-name .v {
    font-size: 13px;
    line-height: 1.6;
    color: var(--muted);
  }

  /* stats + CTA, stacked and right-aligned */
  .blk-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 18px;
  }

  .blk-stats {
    display: flex;
    gap: clamp(28px, 4vw, 52px);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .stat-num {
    font-family: var(--serif);
    font-size: clamp(30px, 3.2vw, 44px);
    font-weight: 400;
    color: var(--luxe);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 5px;
  }

  .all-articles {
    font-size: 11.5px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--luxe);
    opacity: 0.75;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: opacity .25s, gap .25s;
  }
  .all-articles:hover { opacity: 1; gap: 13px; }
  .all-articles .arr { transition: transform .25s; }
  .all-articles:hover .arr { transform: translateX(2px); }

  /* centered scroll arrows */
  .h-scroll {
    position: absolute;
    left: 50%;
    bottom: 30px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    color: var(--luxe);
    opacity: 0.45;
    animation: hbob 2.4s ease-in-out infinite;
  }
  .h-scroll svg { width: 16px; height: 11px; display: block; }
  .h-scroll path {
    stroke: currentColor; stroke-width: 1.2; fill: none;
    stroke-linecap: round; stroke-linejoin: round;
  }
  @keyframes hbob {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(4px); }
  }

  /* headline letter animation — spans are injected by reveal.ts */
  :global(.h-head .letter) {
    display: inline-block;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .5s ease, transform .5s cubic-bezier(.16, 1, .3, 1);
  }
  :global(.h-head .letter.in) {
    opacity: 1;
    transform: none;
  }

  /* mobile ---------------------------------------------------------------- */
  @media (max-width: 680px) {
    .hero-inner {
      padding: clamp(86px, 14vh, 120px) 32px clamp(28px, 5vh, 48px);
      justify-content: flex-start;
    }
    .h-head {
      font-size: clamp(40px, 10.5vw, 56px);
      max-width: 100%;
      margin-bottom: 20px;
    }
    .h-sub { font-size: 14px; max-width: 100%; }

    .h-meta {
      flex-direction: column;
      gap: 28px;
      padding: 22px 32px 0;
      margin-bottom: 72px;
    }
    .blk-right { align-items: flex-start; width: 100%; }
    .blk-stats { gap: 32px; }
    .stat { align-items: flex-start; }
    .h-scroll { bottom: 18px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .h-scroll { animation: none; }
    .h-spotlight { display: none; }
    :global(.h-head .letter) {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
