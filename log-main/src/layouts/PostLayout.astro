---
// Layout for a single post page. Wraps the rendered Markdown in a readable
// article column with a title, date, view counter, and tags.
//
// COMMENTS ARE CURRENTLY DISABLED. The Comments component still exists at
// src/components/Comments.astro (Giscus is already installed on the repo).
// To re-enable comments later: uncomment the import below AND the <Comments />
// line further down. Nothing else needs to change.
import BaseLayout from './BaseLayout.astro';
import ViewCounter from '../components/ViewCounter.astro';
// import Comments from '../components/Comments.astro';

interface PostLink {
  href: string;
  title: string;
}
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;        // unique key for the view counter (e.g. "devlog/my-post")
  section: string;     // "Dev log" or "Writing", shown as an eyebrow label
  readingTime?: number;        // estimated minutes to read
  prev?: PostLink | null;      // older post in the same collection
  next?: PostLink | null;      // newer post in the same collection
  basePath?: string;           // "/devlog" or "/writing", for the "all" link
}
const { title, description, date, tags, slug, section, readingTime, prev, next, basePath } = Astro.props;
const dateLabel = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${title} — Kim Dasha Gustavsson`} description={description}>
  <div class="read-progress" id="read-progress"></div>
  <article class="post-page">
    <div class="wrap">
      <a class="back" href={basePath ?? '/'}>← {basePath ? `all ${section.toLowerCase()}` : 'back'}</a>
      <div class="eyebrow">{section}</div>
      <h1>{title}</h1>
      <div class="post-meta">
        <span>{dateLabel}</span>
        {readingTime && <span>{readingTime} min read</span>}
        <ViewCounter slug={slug} />
      </div>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
      <div class="prose">
        <slot />
      </div>

      {(prev || next) && (
        <nav class="post-nav">
          {prev ? (
            <a class="pn pn-prev" href={prev.href}>
              <span class="pn-dir">← Previous</span>
              <span class="pn-title">{prev.title}</span>
            </a>
          ) : <span></span>}
          {next ? (
            <a class="pn pn-next" href={next.href}>
              <span class="pn-dir">Next →</span>
              <span class="pn-title">{next.title}</span>
            </a>
          ) : <span></span>}
        </nav>
      )}
    </div>
  </article>

  {/* Comments disabled for now. Uncomment the next line (and the import at
      the top) to bring them back. */}
  {/* <Comments /> */}
</BaseLayout>

<style>
  .post-page { padding: 140px clamp(24px, 9vw, 140px) clamp(40px, 6vh, 72px); }
  .post-page .wrap { max-width: 720px; margin: 0 auto; }
  .back { font-size: 13px; color: var(--muted); display: inline-block; margin-bottom: 34px; transition: color .25s; }
  .back:hover { color: var(--luxe); }
  .eyebrow { font-size: 12.5px; letter-spacing: .08em; color: var(--luxe); text-transform: uppercase; font-weight: 600; margin-bottom: 18px; }
  h1 { font-family: var(--serif); font-weight: 400; font-size: clamp(32px, 5vw, 56px); letter-spacing: -.025em; line-height: 1.05; color: var(--luxe); margin-bottom: 20px; }
  .post-meta { display: flex; align-items: center; gap: 18px; font-size: 13px; color: var(--muted); margin-bottom: 16px; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 40px; }
  .post-tags .tag { font-size: 11px; letter-spacing: .03em; color: var(--luxe); border: 1px solid var(--line-strong); padding: 3px 10px; border-radius: 100px; }

  /* Article body typography */
  .prose { font-size: 17px; line-height: 1.7; color: var(--ink); }
  .prose :global(h2) { font-family: var(--serif); font-weight: 500; font-size: 28px; color: var(--luxe); margin: 44px 0 16px; letter-spacing: -.01em; }
  .prose :global(h3) { font-family: var(--serif); font-weight: 500; font-size: 22px; color: var(--luxe); margin: 32px 0 12px; }
  .prose :global(p) { margin: 0 0 20px; }
  .prose :global(a) { color: var(--luxe); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 20px; padding-left: 22px; }
  .prose :global(li) { margin-bottom: 8px; }
  .prose :global(blockquote) { border-left: 2px solid var(--line-strong); padding-left: 20px; margin: 0 0 20px; font-style: italic; color: var(--muted); }
  .prose :global(code) { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: .9em; background: var(--seafoam); padding: 2px 6px; border-radius: 4px; }
  .prose :global(pre) { background: #0e1f4d; color: #f2f1df; padding: 20px; border-radius: 8px; overflow-x: auto; margin: 0 0 24px; font-size: 14px; line-height: 1.6; }
  .prose :global(pre code) { background: none; padding: 0; color: inherit; }
  .prose :global(img) { max-width: 100%; border-radius: 6px; margin: 12px 0; }

  /* Reading progress bar, fixed at the very top of the viewport */
  .read-progress { position: fixed; top: 0; left: 0; height: 3px; width: 0; background: var(--luxe); z-index: 100; transition: width .1s linear; }

  /* Previous / next post navigation at the end of the article */
  .post-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 64px; padding-top: 32px; border-top: 1px solid var(--line); }
  .pn { display: flex; flex-direction: column; gap: 6px; transition: transform .25s; }
  .pn-next { text-align: right; }
  .pn-dir { font-size: 12px; letter-spacing: .04em; text-transform: uppercase; color: var(--muted); }
  .pn-title { font-family: var(--serif); font-size: 18px; line-height: 1.25; color: var(--luxe); }
  .pn-prev:hover { transform: translateX(-3px); }
  .pn-next:hover { transform: translateX(3px); }
  @media (max-width: 620px) {
    .post-nav { grid-template-columns: 1fr; }
    .pn-next { text-align: left; }
  }
</style>

<script>
  // Update the reading-progress bar as the article scrolls past.
  const bar = document.getElementById('read-progress');
  function updateProgress() {
    const h = document.documentElement;
    const scrolled = h.scrollTop;
    const max = h.scrollHeight - h.clientHeight;
    const pct = max > 0 ? (scrolled / max) * 100 : 0;
    if (bar) bar.style.width = pct + '%';
  }
  window.addEventListener('scroll', updateProgress, { passive: true });
  window.addEventListener('resize', updateProgress);
  updateProgress();
</script>
