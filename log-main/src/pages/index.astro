---
// Home page: hero, then the dev log list, then the writing list. Posts are
// loaded from the content collections, filtered for drafts, and sorted newest
// first. Rendering is delegated to the reusable PostList component.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostList from '../components/PostList.astro';
import { getPostsByCategory } from '../lib/posts';

const devlogPosts = await getPostsByCategory('devlog');
const writingPosts = await getPostsByCategory('writing');
---

<BaseLayout rail={[
  { id: 'top', label: 'Intro' },
  { id: 'devlog', label: 'Dev log' },
  { id: 'writing', label: 'Writing' },
]}>
  <Hero devlogCount={devlogPosts.length} writingCount={writingPosts.length} />

  <section class="block" id="devlog">
    <PostList
      id="devlog"
      label="Dev log"
      heading="Recent entries"
      basePath="/devlog"
      variant="date"
      posts={devlogPosts}
    />
  </section>

  <section class="block" id="writing">
    <PostList
      id="writing"
      label="Writing"
      heading="Longer thoughts"
      basePath="/writing"
      variant="number"
      posts={writingPosts}
    />
  </section>

  <script>
    // The text-wave hover effect only applies to the hero, so it's
    // initialized here rather than in BaseLayout.
    import { initTextWave } from '../scripts/text-wave';
    initTextWave();
  </script>
</BaseLayout>
