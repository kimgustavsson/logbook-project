---
// Dev log index — the full list of every dev log entry. The home page shows
// only the most recent few; this page shows all of them. Rendering reuses the
// same PostList component so the styling stays identical everywhere.
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('devlog', ({ data }) => !data.draft);
const posts = entries
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.date,
    tags: entry.data.tags,
  }));
---

<BaseLayout title="Dev log — Kim Dasha Gustavsson" description="Every dev log entry.">
  <section class="block list-page">
    <PostList
      id="devlog"
      label="Dev log"
      heading="All entries"
      basePath="/devlog"
      variant="date"
      posts={posts}
      filterable={true}
    />

    <div class="page-end">
      <a class="end-link" href="/">← Home</a>
      <a class="end-link" href="#" id="to-top">Back to top ↑</a>
    </div>
  </section>
</BaseLayout>

<style>
  .list-page { padding-top: 132px; }
  .page-end { max-width: var(--maxw-read); margin: 48px auto 0; display: flex; justify-content: space-between; align-items: center; padding-top: 34px; border-top: 1px solid var(--line); }
  .end-link { font-size: 14px; color: var(--muted); transition: color .2s; }
  .end-link:hover { color: var(--luxe); }
</style>

<script>
  document.getElementById('to-top')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
